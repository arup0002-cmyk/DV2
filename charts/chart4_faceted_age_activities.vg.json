{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Kids' Mobile Habits (Draft)", "color": "#cbd5e1"},
  "width": "container", 
  "height": 280,
  "background": "transparent",
  "data": {"url": "datasets/kids_mobile_usage_by_age.csv"},
  "mark": "bar",
  "encoding": {
    "x": {"field": "Activity", "type": "nominal", "axis": {"labelColor": "#94a3b8", "titleColor": "#94a3b8", "labelAngle": -45}},
    "y": {"field": "Percentage", "type": "quantitative", "aggregate": "mean", "axis": {"labelColor": "#94a3b8", "titleColor": "#94a3b8", "gridColor": "#334155"}},
    "color": {"field": "Age_Group", "type": "nominal"}
  },
  "config": {"view": {"stroke": "transparent"}}
}
