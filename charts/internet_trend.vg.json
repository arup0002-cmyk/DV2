{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 700,
  "height": 400,

  "data": {
    "url": "/data/australia_internet_usage.csv"
  },

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 4,
    "color": "#38bdf8"
  },

  "encoding": {

    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year"
    },

    "y": {
      "field": "Internet_Usage_Percentage",
      "type": "quantitative",
      "title": "Internet Usage (%)"
    },

    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal"
      },
      {
        "field": "Individuals using the Internet (% of population)",
        "type": "quantitative"
      }
    ]

  },

  "config": {

    "background": "#0f172a",

    "axis": {
      "labelColor": "white",
      "titleColor": "white",
      "gridColor": "#334155",
      "domainColor": "#94a3b8",
      "tickColor": "#94a3b8"
    },

    "view": {
      "stroke": "transparent"
    }
  }
}
