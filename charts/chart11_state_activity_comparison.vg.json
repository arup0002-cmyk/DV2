{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Mobile Activities Across Australian States",
    "subtitle": "Comparing smartphone behaviour by region",
    "color": "#cbd5e1",
    "subtitleColor": "#94a3b8"
  },

  "width": 600,
  "height": 320,

  "background": "transparent",

  "data": {
    "url": "datasets/kids_mobile_usage_by_state_2020.csv",
    "format": {"type": "csv"}
  },

  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 4
  },

  "encoding": {
    "x": {
      "field": "Percentage",
      "type": "quantitative",
      "title": "Participation Rate (%)",
      "axis": {
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8",
        "gridColor": "#334155"
      }
    },

    "y": {
      "field": "State",
      "type": "nominal",
      "sort": "-x",
      "title": "State",
      "axis": {
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8"
      }
    },

    "color": {
      "field": "Activity",
      "type": "nominal",
      "legend": {
        "orient": "bottom",
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8"
      }
    },

    "tooltip": [
      {"field": "State"},
      {"field": "Activity"},
      {"field": "Percentage"}
    ]
  },

  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}
