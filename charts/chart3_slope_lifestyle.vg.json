{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Lifestyle Reasons for Internet Usage",
  "width": 300,
  "height": 300,
  "data": {"url": "datasets/reasons_for_internet_usage.csv"},
  "transform": [
    {"fold": ["2014-15_Pct", "2016-17_Pct"], "as": ["Year", "Percentage"]}
  ],
  "mark": {"type": "line", "point": true},
  "encoding": {
    "x": {"field": "Year", "type": "nominal"},
    "y": {"field": "Percentage", "type": "quantitative"},
    "color": {"field": "Reason", "type": "nominal", "scale": {"scheme": "colorblind"}}
  }
}
