{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Mobile Activities Among Australian Children",
    "subtitle": "Play Games Usage by Age Group (2015–2020)",
    "color": "#cbd5e1",
    "subtitleColor": "#94a3b8"
  },

  "width": 500,
  "height": 300,

  "background": "transparent",

  "data": {
    "url": "datasets/kids_mobile_usage_by_age.csv",
    "format": {"type": "csv"}
  },

  "transform": [
    {
      "filter": "datum.Activity == 'Play games'"
    }
  ],

  "mark": {
    "type": "line",
    "point": true,
    "strokeWidth": 4
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "axis": {
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8"
      }
    },

    "y": {
      "field": "Percentage",
      "type": "quantitative",
      "axis": {
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8",
        "gridColor": "#334155"
      }
    },

    "color": {
      "field": "Age_Group",
      "type": "nominal",
      "legend": {
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8"
      }
    },

    "tooltip": [
      {"field": "Age_Group"},
      {"field": "Year"},
      {"field": "Percentage"}
    ]
  },

  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}
