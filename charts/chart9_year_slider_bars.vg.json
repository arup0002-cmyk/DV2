{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Cross-Sectional Activity Demographics by Year", "color": "#cbd5e1"},
  "width": "container",
  "height": 300,
  "background": "transparent",
  "data": {"url": "datasets/kids_mobile_usage_by_age.csv"},
  "params": [
    {"name": "Select_Year", "value": 2020, "bind": {"input": "range", "min": 2015, "max": 2020, "step": 1, "name": "Timeline Slider: "}}
  ],
  "transform": [{"filter": "datum.Year == Select_Year"}],
  "mark": "bar",
  "encoding": {
    "x": {"field": "Activity", "type": "nominal", "title": "Mobile Activity", "axis": {"labelColor": "#94a3b8", "titleColor": "#94a3b8", "labelAngle": -30}},
    "y": {"field": "Percentage", "type": "quantitative", "aggregate": "mean", "title": "Average Engagement (%)", "axis": {"labelColor": "#94a3b8", "titleColor": "#94a3b8", "gridColor": "#334155"}},
    "color": {"field": "Age_Group", "type": "nominal", "scale": {"scheme": "accent"}, "legend": {"titleColor": "#94a3b8", "labelColor": "#94a3b8"}},
    "tooltip": [{"field": "Activity", "type": "nominal"}, {"field": "Age_Group", "type": "nominal"}, {"field": "Percentage", "aggregate": "mean", "type": "quantitative", "title": "Mean Rate (%)", "format": ".1f"}]
  },
  "config": {"view": {"stroke": "transparent"}}
}
