{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Mobile Activity by Age Group (2020)", "color": "#e2e8f0", "fontSize": 14},
  "width": 300,
  "height": 250,
  "background": "transparent",
  "data": {
    "values": [
      {"Activity": "Games", "Age_Group": "6-9", "Percentage": 45},
      {"Activity": "Games", "Age_Group": "10-11", "Percentage": 55},
      {"Activity": "Apps", "Age_Group": "6-9", "Percentage": 30},
      {"Activity": "Apps", "Age_Group": "10-11", "Percentage": 40},
      {"Activity": "Texts", "Age_Group": "6-9", "Percentage": 20},
      {"Activity": "Texts", "Age_Group": "10-11", "Percentage": 50}
    ]
  },
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadius": 4},
      "encoding": {
        "x": {"field": "Activity", "type": "nominal", "axis": {"labelColor": "#94a3b8", "titleColor": "#94a3b8"}},
        "y": {"field": "Percentage", "type": "quantitative", "axis": {"gridColor": "#334155", "labelColor": "#94a3b8", "titleColor": "#94a3b8"}},
        "color": {"field": "Age_Group", "type": "nominal", "scale": {"scheme": "set2"}, "legend": {"titleColor": "#94a3b8", "labelColor": "#94a3b8"}}
      }
    },
    {
      "mark": {"type": "text", "dy": -10, "color": "#e2e8f0"},
      "encoding": {
        "x": {"field": "Activity", "type": "nominal"},
        "y": {"field": "Percentage", "type": "quantitative"},
        "text": {"field": "Percentage", "type": "quantitative"}
      }
    }
  ],
  "config": {"view": {"stroke": "transparent"}}
}
