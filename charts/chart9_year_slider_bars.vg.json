{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 350, 
  "height": 250, 
  "background": "transparent",
  "title": {"text": "Usage Growth", "color": "white"},
  "data": {
    "values": [
      {"Year": "2015", "Pct": 45, "Age": "6-9"}, {"Year": "2020", "Pct": 58, "Age": "6-9"},
      {"Year": "2015", "Pct": 69, "Age": "12-13"}, {"Year": "2020", "Pct": 82, "Age": "12-13"}
    ]
  },
  "mark": {"type": "line", "point": true},
  "encoding": {
    "x": {"field": "Year", "type": "ordinal", "axis": {"labelColor": "white", "titleColor": "white"}},
    "y": {"field": "Pct", "type": "quantitative", "axis": {"labelColor": "white", "titleColor": "white", "gridColor": "#334155"}},
    "color": {"field": "Age", "type": "nominal", "scale": {"scheme": "accent"}}
  }
}
