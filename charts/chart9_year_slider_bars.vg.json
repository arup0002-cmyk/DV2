{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Mobile Activity by Age Group (2020)", "color": "#cbd5e1"},
  "width": 350,
  "height": 300,
  "background": "transparent",
  "data": {
    "values": [
      {"Activity": "Games", "Age_Group": "6-9", "Percentage": 45},
      {"Activity": "Games", "Age_Group": "10-11", "Percentage": 55},
      {"Activity": "Apps", "Age_Group": "6-9", "Percentage": 30},
