{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "Mobile Activities Among Australian Children",
    "subtitle": "Play Games Usage by Age Group (2015–2020)",
    "color": "#cbd5e1",
    "subtitleColor": "#94a3b8",
    "fontSize": 20
  },

  "width": 600,
  "height": 320,

  "background": "transparent",

  "data": {
    "url": "datasets/kids_mobile_usage_by_age.csv",
    "format": {
      "type": "csv"
    }
  },

  "transform": [
    {
      "filter": "datum.Activity == 'Play games'"
    }
  ],

  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 120
    },
    "strokeWidth": 4
  },

  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year",
      "axis": {
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8",
        "grid": false
      }
    },

    "y": {
      "field": "Percentage",
      "type": "quantitative",
      "title": "Participation Rate (%)",
      "axis": {
        "labelColor": "#94a3b8",
        "titleColor": "#94a3b8",
        "gridColor": "#334155"
      }
    },

    "color": {
  "field": "Age_Group",
  "type": "nominal",
  "scale": {
    "domain": [
      "6-9 year olds",
      "10-11 year olds",
      "12-13 year olds"
    ],
    "range": [
      "#ec4899",
      "#38bdf8",
      "#f59e0b"
    ]
  },
  "legend": {
    "orient": "bottom",
    "title": "Age Group",
    "labelColor": "#94a3b8",
    "titleColor": "#94a3b8"
  }
},

    "tooltip": [
      {
        "field": "Age_Group",
        "title": "Age Group"
      },
      {
        "field": "Year"
      },
      {
        "field": "Percentage",
        "title": "Participation (%)",
        "format": ".1f"
      }
    ]
  },

  "config": {
    "view": {
      "stroke": "transparent"
    }
  }
}
